# EKMA AI environment template
# Copy to .env for local use. Never commit real values.

# Runtime environment: development | staging | production
EKMA_ENV=development

# n8n (reserved until deployment is approved)
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=replace_with_a_unique_secret
N8N_USER_MANAGEMENT_JWT_SECRET=replace_with_a_unique_secret

# Database (reserved for the PostgreSQL phase)
POSTGRES_DB=ekma_ai
POSTGRES_USER=ekma_ai
POSTGRES_PASSWORD=replace_with_a_unique_secret
POSTGRES_PORT=5432

# Observability (reserved)
LOG_LEVEL=info
TZ=Asia/Tehran
